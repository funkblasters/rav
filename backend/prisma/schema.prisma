// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL_POOLED")
  directUrl = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String?    @unique
  displayName  String
  passwordHash String?
  status       UserStatus @default(REGISTERED)
  role         Role       @default(MEMBER)
  clubRole     ClubRole   @default(ORDINARY_ASSOCIATE)
  cardNumber   String?    @unique
  createdAt    DateTime   @default(now())

  flagsAdded       Flag[]  @relation("AddedBy")
  contributedFlags Flag[]  @relation("FlagContributors")
  invites          Invite[]

  @@map("users")
}

model Flag {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  countryCode String  @default("XX")
  subdivisionCode String?
  city      String?
  latitude  Float?
  longitude Float?
  imageUrl  String?
  acquiredAt DateTime
  isPublic  Boolean    @default(true)
  isVariant Boolean    @default(false)
  description String?
  continent String?

  addedBy   User      @relation("AddedBy", fields: [addedById], references: [id], onDelete: Cascade)
  addedById String    @db.Uuid

  contributors User[] @relation("FlagContributors")

  createdAt DateTime   @default(now())
  publishedAt DateTime?

  @@map("flags")
}

model Invite {
  id        String     @id @default(uuid()) @db.Uuid
  email     String     @unique
  clubRole  ClubRole
  cardNumber String?

  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String  @db.Uuid

  createdAt DateTime   @default(now())

  @@map("invites")
}

enum Role {
  ADMIN
  MEMBER
}

enum UserStatus {
  REGISTERED
  PENDING
  EXTERNAL
}

enum ClubRole {
  CHAIRMAN
  VICE_CHAIRMAN
  HONORARY_CHAIRMAN
  TREASURER
  SECRETARY
  ORDINARY_ASSOCIATE
}

model FailedImport {
  id        String   @id @default(uuid()) @db.Uuid
  row       Int
  flagName  String
  reason    String
  rawData   String   // JSON: { date, contributors, continent, isVariant }
  createdAt DateTime @default(now())

  @@map("failed_imports")
}

model NewsItem {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  link      String
  imageUrl  String?
  source    String?
  pubDate   DateTime
  createdAt DateTime @default(now())

  @@map("news_items")
}

model Settings {
  id        String     @id @default("app")
  mostWantedName String?
  mostWantedImageUrl String?
  mostWantedAcquiredAt DateTime?
  mostWantedDescription String?
  featuredNewsTitle String?
  featuredNewsLink String?
  featuredNewsImageUrl String?
  featuredNewsBody String?

  @@map("settings")
}
