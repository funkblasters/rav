# Server Configuration
PORT=4000
NODE_ENV=development

# SECURITY: JWT Secrets (CRITICAL - must be strong random strings in production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MINIMUM 32 characters, alphanumeric or special characters
JWT_SECRET=change-me-in-production
REFRESH_TOKEN_SECRET=change-me-in-production

# Frontend Origin (REQUIRED in production)
# Comma-separated list for multiple origins
FRONTEND_URL=https://your-app.vercel.app

# Development-only origins (NGROK, localhost tunnels, etc.)
# ⚠️ ONLY WORKS IN DEVELOPMENT MODE - THROWS ERROR IN PRODUCTION
# Example: DEV_ORIGINS=https://abc123.ngrok.io,https://def456.ngrok.io
# DEV_ORIGINS=

# Database (PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/rav

# Rate Limiting (optional, defaults shown)
# RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=5      # Max auth attempts per window

# Cookie Domain (for multi-domain setup)
# COOKIE_DOMAIN=.yourdomain.com
